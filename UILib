    task.wait(1.4)

    -- Outro Animation
    animate(SplashLabel, 0.3, Enum.EasingStyle.Quad, {TextTransparency = 1})
    animate(LoadingBarBg, 0.3, Enum.EasingStyle.Quad, {BackgroundTransparency = 1})
    animate(LoadingBarFill, 0.3, Enum.EasingStyle.Quad, {BackgroundTransparency = 1})
    animate(SplashStroke, 0.4, Enum.EasingStyle.Quad, {Transparency = 1})
    animate(SplashFrame, 0.4, Enum.EasingStyle.Back, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0), BackgroundTransparency = 1})
    task.wait(0.4)
    SplashFrame:Destroy()

    -- ==========================================
    -- MODERN MAIN WINDOW DESIGN
