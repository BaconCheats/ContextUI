    ContentContainer.Size = UDim2.new(1, -180, 1, -75)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    local WindowActions = {Tabs = {}}

    -- ==========================================
    -- TAB COMPONENT
    -- ==========================================
    function WindowActions:CreateTab(tabName)
        local TabButton = Instance.new("TextButton")
        local TabCorner = Instance.new("UICorner")
        local Page = Instance.new("ScrollingFrame")
        local PageUIList = Instance.new("UIListLayout")

        TabButton.Size = UDim2.new(1, 0, 0, 34)
        TabButton.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
        TabButton.BackgroundTransparency = 1
        TabButton.Text = "   " .. tabName
        TabButton.TextColor3 = Color3.fromRGB(140, 140, 150)
        TabButton.Font = Enum.Font.GothamMedium
        TabButton.TextSize = 13
        TabButton.TextXAlignment = Enum.TextXAlignment.Left
        TabButton.Parent = TabContainer

        TabCorner.CornerRadius = UDim.new(0, 6)
        TabCorner.Parent = TabButton

        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 2
        Page.ScrollBarImageColor3 = Color3.fromRGB(40, 40, 50)
        Page.Parent = ContentContainer

        PageUIList.Padding = UDim.new(0, 8)
        PageUIList.Parent = Page

        local function activate()
            for _, t in pairs(WindowActions.Tabs) do
                t.Page.Visible = false
                animate(t.Button, 0.2, Enum.EasingStyle.Quad, {BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(140, 140, 150)})
            end
            Page.Visible = true
            animate(TabButton, 0.2, Enum.EasingStyle.Quad, {BackgroundTransparency = 0, BackgroundColor3 = Color3.fromRGB(30, 30, 40), TextColor3 = Color3.fromRGB(0, 150, 255)})
        end

        TabButton.MouseButton1Click:Connect(activate)
        table.insert(WindowActions.Tabs, {Button = TabButton, Page = Page})

        if #WindowActions.Tabs == 1 then activate() end

        local ElementActions = {}

        -- BUTTON COMPONENT
        function ElementActions:CreateButton(name, callback)
            local Button = Instance.new("TextButton")
            local BtnStroke = Instance.new("UIStroke")
            Button.Size = UDim2.new(1, 0, 0, 36)
            Button.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
            Button.Text = "   " .. name
            Button.TextColor3 = Color3.fromRGB(230, 230, 235)
            Button.Font = Enum.Font.GothamMedium
            Button.TextSize = 13
            Button.TextXAlignment = Enum.TextXAlignment.Left
            Button.Parent = Page
            Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 6)

            BtnStroke.Color = Color3.fromRGB(35, 35, 42)
            BtnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            BtnStroke.Parent = Button

            Button.MouseEnter:Connect(function() 
                animate(Button, 0.2, Enum.EasingStyle.Quad, {BackgroundColor3 = Color3.fromRGB(28, 28, 36)})
                animate(BtnStroke, 0.2, Enum.EasingStyle.Quad, {Color = Color3.fromRGB(0, 150, 255)})
            end)
            Button.MouseLeave:Connect(function() 
                animate(Button, 0.2, Enum.EasingStyle.Quad, {BackgroundColor3 = Color3.fromRGB(22, 22, 28)})
                animate(BtnStroke, 0.2, Enum.EasingStyle.Quad, {Color = Color3.fromRGB(35, 35, 42)})
            end)
            Button.MouseButton1Click:Connect(callback)
        end

        -- TOGGLE / CHECKBOX COMPONENT
        function ElementActions:CreateToggle(name, default, callback)
            local state = default or false
            local ToggleFrame = Instance.new("Frame")
            local FrameStroke = Instance.new("UIStroke")
            local Label = Instance.new("TextLabel")
            local SwitchBg = Instance.new("TextButton")
            local SwitchBall = Instance.new("Frame")

            ToggleFrame.Size = UDim2.new(1, 0, 0, 38)
            ToggleFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
            ToggleFrame.Parent = Page
            Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 6)

            FrameStroke.Color = Color3.fromRGB(35, 35, 42)
            FrameStroke.Parent = ToggleFrame

            Label.Size = UDim2.new(1, -60, 1, 0)
            Label.Position = UDim2.new(0, 12, 0, 0)
            Label.BackgroundTransparency = 1
            Label.Text = name
            Label.TextColor3 = Color3.fromRGB(220, 220, 225)
            Label.Font = Enum.Font.GothamMedium
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = ToggleFrame

            SwitchBg.Size = UDim2.new(0, 34, 0, 18)
            SwitchBg.Position = UDim2.new(1, -46, 0.5, -9)
            SwitchBg.BackgroundColor3 = state and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(45, 45, 55)
            SwitchBg.Text = ""
            SwitchBg.Parent = ToggleFrame
            Instance.new("UICorner", SwitchBg).CornerRadius = UDim.new(1, 0)

            SwitchBall.Size = UDim2.new(0, 14, 0, 14)
            SwitchBall.Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            SwitchBall.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            SwitchBall.Parent = SwitchBg
            Instance.new("UICorner", SwitchBall).CornerRadius = UDim.new(1, 0)

            local function update()
                local targetBg = state and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(45, 45, 55)
                local targetPos = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
                animate(SwitchBg, 0.2, Enum.EasingStyle.Quad, {BackgroundColor3 = targetBg})
                animate(SwitchBall, 0.2, Enum.EasingStyle.Back, {Position = targetPos})
                callback(state)
            end

            SwitchBg.MouseButton1Click:Connect(function()
                state = not state
                update()
            end)
        end

        -- SLIDER COMPONENT
        function ElementActions:CreateSlider(name, min, max, default, callback)
            local SliderFrame = Instance.new("Frame")
            local FrameStroke = Instance.new("UIStroke")
            local Label = Instance.new("TextLabel")
            local ValueLabel = Instance.new("TextLabel")
            local Track = Instance.new("TextButton")
            local Fill = Instance.new("Frame")

            SliderFrame.Size = UDim2.new(1, 0, 0, 48)
            SliderFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
            SliderFrame.Parent = Page
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 6)

            FrameStroke.Color = Color3.fromRGB(35, 35, 42)
            FrameStroke.Parent = SliderFrame

            Label.Size = UDim2.new(0.5, 0, 0, 22)
            Label.Position = UDim2.new(0, 12, 0, 5)
            Label.BackgroundTransparency = 1
            Label.Text = name
            Label.TextColor3 = Color3.fromRGB(220, 220, 225)
            Label.Font = Enum.Font.GothamMedium
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = SliderFrame

            ValueLabel.Size = UDim2.new(0.5, -12, 0, 22)
            ValueLabel.Position = UDim2.new(0.5, 0, 0, 5)
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.Text = tostring(default)
            ValueLabel.TextColor3 = Color3.fromRGB(0, 150, 255)
            ValueLabel.Font = Enum.Font.GothamBold
            ValueLabel.TextSize = 13
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
            ValueLabel.Parent = SliderFrame

            Track.Size = UDim2.new(1, -24, 0, 5)
            Track.Position = UDim2.new(0, 12, 0, 33)
            Track.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
            Track.Text = ""
            Track.Parent = SliderFrame
            Instance.new("UICorner", Track)

            Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
            Fill.Parent = Track
            Instance.new("UICorner", Fill)

            local sliding = false
            local function move(input)
                local ratio = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local value = math.floor(min + (max - min) * ratio)
                ValueLabel.Text = tostring(value)
                Fill.Size = UDim2.new(ratio, 0, 1, 0)
                callback(value)
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true move(input) end
            end)
            Track.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then move(input) end
            end)
        end

        -- SINGLE & MULTI SELECT DROPDOWN COMPONENT
        function ElementActions:CreateDropdown(name, list, isMulti, callback)
            local Expanded = false
            local Selected = {}
            
            local DropdownFrame = Instance.new("Frame")
            local FrameStroke = Instance.new("UIStroke")
            local MainButton = Instance.new("TextButton")
            local Container = Instance.new("Frame")
            local ContainerList = Instance.new("UIListLayout")

            DropdownFrame.Size = UDim2.new(1, 0, 0, 36)
            DropdownFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
            DropdownFrame.ClipsDescendants = true
            DropdownFrame.Parent = Page
            Instance.new("UICorner", DropdownFrame).CornerRadius = UDim.new(0, 6)

            FrameStroke.Color = Color3.fromRGB(35, 35, 42)
            FrameStroke.Parent = DropdownFrame

            MainButton.Size = UDim2.new(1, 0, 0, 36)
            MainButton.BackgroundTransparency = 1
            MainButton.Text = "   " .. name .. "  —  Select..."
            MainButton.TextColor3 = Color3.fromRGB(180, 180, 190)
            MainButton.Font = Enum.Font.GothamMedium
            MainButton.TextSize = 13
            MainButton.TextXAlignment = Enum.TextXAlignment.Left
            MainButton.Parent = DropdownFrame

            Container.Size = UDim2.new(1, 0, 0, #list * 28)
            Container.Position = UDim2.new(0, 0, 0, 36)
            Container.BackgroundTransparency = 1
            Container.Parent = DropdownFrame
            ContainerList.Parent = Container

            local function refreshText()
                if #Selected == 0 then
                    MainButton.Text = "   " .. name .. "  —  Select..."
                    MainButton.TextColor3 = Color3.fromRGB(180, 180, 190)
                else
                    MainButton.Text = "   " .. name .. "  —  [" .. table.concat(Selected, ", ") .. "]"
                    MainButton.TextColor3 = Color3.fromRGB(0, 150, 255)
                end
            end

            local function toggleDropdown(open)
                Expanded = open
                local targetHeight = open and (38 + (#list * 28)) or 36
                animate(DropdownFrame, 0.25, Enum.EasingStyle.Quad, {Size = UDim2.new(1, 0, 0, targetHeight)})
                animate(FrameStroke, 0.25, Enum.EasingStyle.Quad, {Color = open and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(35, 35, 42)})
            end

            MainButton.MouseButton1Click:Connect(function()
                toggleDropdown(not Expanded)
            end)

            for _, item in ipairs(list) do
                local ItemButton = Instance.new("TextButton")
                ItemButton.Size = UDim2.new(1, 0, 0, 26)
                ItemButton.BackgroundTransparency = 1
                ItemButton.Text = "     " .. tostring(item)
                ItemButton.TextColor3 = Color3.fromRGB(150, 150, 160)
                ItemButton.Font = Enum.Font.Gotham
                ItemButton.TextSize = 12
                ItemButton.TextXAlignment = Enum.TextXAlignment.Left
                ItemButton.Parent = Container

                ItemButton.MouseEnter:Connect(function() animate(ItemButton, 0.15, Enum.EasingStyle.Quad, {TextColor3 = Color3.fromRGB(255, 255, 255)}) end)
                ItemButton.MouseLeave:Connect(function() 
                    if not table.find(Selected, item) then
                        animate(ItemButton, 0.15, Enum.EasingStyle.Quad, {TextColor3 = Color3.fromRGB(150, 150, 160)}) 
                    end
                end)

                ItemButton.MouseButton1Click:Connect(function()
                    if isMulti then
                        if table.find(Selected, item) then
                            table.remove(Selected, table.find(Selected, item))
                            animate(ItemButton, 0.15, Enum.EasingStyle.Quad, {TextColor3 = Color3.fromRGB(150, 150, 160)})
                        else
                            table.insert(Selected, item)
                            animate(ItemButton, 0.15, Enum.EasingStyle.Quad, {TextColor3 = Color3.fromRGB(0, 150, 255)})
                        end
                        refreshText()
                        callback(Selected)
                    else
                        Selected = {item}
                        refreshText()
                        toggleDropdown(false)
                        callback(item)
                    end
                end)
            end
        end

        return ElementActions
    end

    return WindowActions
end

return ContextsUI
